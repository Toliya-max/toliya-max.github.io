<Window x:Class="LichessBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lichess Bot Controller" Height="750" Width="1040"
        Background="{StaticResource BgDarkBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Icon="app.ico">

    <!-- Window Fade-In -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="24,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.3">
                    <GradientStop Color="#FF120e08" Offset="0"/>
                    <GradientStop Color="#FF1a1410" Offset="0.5"/>
                    <GradientStop Color="#FF0e0b07" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <DockPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="L I C H E S S   B O T" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Opacity="0.85"/>
                        <TextBlock Text="Controller" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="LblGames" Text="" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,14,0"/>
                        <Border x:Name="StatusBadge" CornerRadius="14" Padding="14,6" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF1e1812" Offset="0"/>
                                    <GradientStop Color="#FF141010" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#FF4a3d30" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock x:Name="LblStatus" Text="Ready" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
                <!-- amber sweep line -->
                <Rectangle Height="1" VerticalAlignment="Bottom" Margin="0,0,0,-15" HorizontalAlignment="Stretch">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00d4985a" Offset="0"/>
                            <GradientStop Color="#59d4985a" Offset="0.2"/>
                            <GradientStop Color="#59d4985a" Offset="0.8"/>
                            <GradientStop Color="#00d4985a" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>
        </Border>

        <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════ LEFT SIDEBAR ═══════════════ -->
            <Border Grid.Column="0" Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <TabControl Background="Transparent" BorderThickness="0" Margin="6,6,6,6">

                    <!-- ============================ TAB 1: CONTROLS ============================ -->
                    <TabItem Header="Controls">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,14,12,12">

                                <!-- Start / Stop / Resign -->
                                <Button x:Name="BtnStart" Content="&#x25B6;  Start Bot" Click="BtnStart_Click"
                                        Style="{StaticResource StartButton}" Margin="0,0,0,7"/>
                                <Button x:Name="BtnStop" Content="&#x25A0;  Stop Bot" Click="BtnStop_Click" IsEnabled="False"
                                        Style="{StaticResource StopButton}" Margin="0,0,0,7"/>
                                <Button x:Name="BtnResignAll" Content="Resign All Games" Click="BtnResignAll_Click" Style="{StaticResource AccentButton}" Margin="0,0,0,16">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF2a2018" Offset="0"/>
                                            <GradientStop Color="#FF382a20" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>
                                <TextBlock Text="TIME CONTROL" FontSize="10" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.7"/>

                                <UniformGrid Columns="3" Margin="0,0,0,6">
                                    <Button x:Name="BtnPresetBullet" Content="1+0" Click="BtnPresetBullet_Click" Style="{StaticResource PresetButton}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnPresetBlitz" Content="3+0" Click="BtnPresetBlitz_Click" Style="{StaticResource PresetButton}" Margin="2,0,2,0"/>
                                    <Button x:Name="BtnPresetRapid" Content="10+0" Click="BtnPresetRapid_Click" Style="{StaticResource PresetButton}" Margin="4,0,0,0"/>
                                </UniformGrid>
                                <UniformGrid Columns="3" Margin="0,0,0,14">
                                    <Button x:Name="BtnPresetHyper" Content="0.5+0" Click="BtnPresetHyper_Click" Style="{StaticResource PresetButton}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnPresetClassical" Content="15+10" Click="BtnPresetClassical_Click" Style="{StaticResource PresetButton}" Margin="2,0,2,0"/>
                                    <Button x:Name="BtnPresetCustom" Content="Custom" Click="BtnPresetCustom_Click" Style="{StaticResource PresetButton}" Margin="4,0,0,0"/>
                                </UniformGrid>

                                <!-- Custom Time Panel -->
                                <StackPanel x:Name="CustomTimePanel" Visibility="Collapsed" Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Minutes" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="TxtMinutes" Text="3" Style="{StaticResource RoundedTextBox}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Increment" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="TxtIncrement" Text="0" Style="{StaticResource RoundedTextBox}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,10"/>

                                <!-- Copy / Clear / Updates -->
                                <UniformGrid Columns="2" Margin="0,0,0,6">
                                    <Button x:Name="BtnCopy" Content="Copy Logs" Click="BtnCopy_Click" Style="{StaticResource PresetButton}" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnClear" Content="Clear" Click="BtnClear_Click" Style="{StaticResource PresetButton}" Margin="4,0,0,0"/>
                                </UniformGrid>
                                <Button x:Name="BtnCheckUpdates" Content="Check for Updates" Click="BtnCheckUpdates_Click" Style="{StaticResource PresetButton}" Margin="0,0,0,6"/>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,6,0,10"/>
                                <TextBlock Text="LICENSE" FontSize="10" FontWeight="Bold" Margin="0,0,0,8" Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.7"/>
                                <Button x:Name="BtnLicense" Content="Manage License" Click="BtnLicense_Click" Style="{StaticResource PresetButton}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="LblLicenseStatus" Text="" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="2,0,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ============================ TAB 2: SETTINGS ============================ -->
                    <TabItem Header="Settings">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,14,12,12">

                                <TextBlock Text="Lichess API Token" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtApiToken" Text="" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,16"/>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>
                                <TextBlock Text="CHALLENGE" FontSize="10" FontWeight="Bold" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.7"/>

                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Auto Challenger" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <CheckBox x:Name="ChkChallenger" IsChecked="True" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitch}"/>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Rated Matches" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <CheckBox x:Name="ChkRated" IsChecked="False" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitch}"/>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Auto-Resign" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <CheckBox x:Name="ChkAutoResign" IsChecked="True" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitch}"/>
                                </DockPanel>

                                <TextBlock Text="Resign Threshold" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtResignThreshold" Text="-5.0" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,10"/>

                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Accept Rematch" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <CheckBox x:Name="ChkRematch" IsChecked="True" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitch}"/>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Include Chess960 challenges" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                               ToolTip="Auto-challenger will randomly send Chess960 or standard challenges"/>
                                    <CheckBox x:Name="ChkIncludeChess960" IsChecked="False" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitch}"/>
                                </DockPanel>

                                <TextBlock Text="Min Opponent Rating" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtRating" Text="1900" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="Max Games (0 = unlimited)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtMaxGames" Text="0" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,10"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ============================ TAB 3: ENGINE ============================ -->
                    <TabItem Header="Engine">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,14,12,12">

                                <TextBlock Text="Engine Path" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,10">
                                    <Button x:Name="BtnBrowseEngine" Content="..." DockPanel.Dock="Right" Margin="4,0,0,0" Width="34" Click="BtnBrowseEngine_Click" Style="{StaticResource PresetButton}"/>
                                    <TextBox x:Name="TxtEnginePath" IsReadOnly="True" Text="Default Stockfish 18" Style="{StaticResource RoundedTextBox}"/>
                                </DockPanel>

                                <TextBlock Text="Opening Book (.bin)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,14">
                                    <Button x:Name="BtnBrowseBook" Content="..." DockPanel.Dock="Right" Margin="4,0,0,0" Width="34" Click="BtnBrowseBook_Click" Style="{StaticResource PresetButton}"/>
                                    <TextBox x:Name="TxtBookPath" IsReadOnly="True" Text="None" Style="{StaticResource RoundedTextBox}"/>
                                </DockPanel>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>

                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="Use NNUE" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <CheckBox x:Name="ChkNNUE" IsChecked="True" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitch}"/>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock Text="Pondering" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <CheckBox x:Name="ChkPonder" IsChecked="False" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitch}"/>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Skill Level" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <TextBlock x:Name="LblSkill" Text="20" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="Bold"/>
                                </DockPanel>
                                <Slider x:Name="SliderSkill" Minimum="0" Maximum="20" Value="20" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="SliderSkill_ValueChanged" Margin="0,0,0,12"/>

                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Move Speed" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <TextBlock x:Name="LblSpeed" Text="1.0x" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="Bold"/>
                                </DockPanel>
                                <Slider x:Name="SliderSpeed" Minimum="0.1" Maximum="3.0" Value="1.0" IsSnapToTickEnabled="True" TickFrequency="0.1" ValueChanged="SliderSpeed_ValueChanged" Margin="0,0,0,12"/>

                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Max Depth" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <TextBlock x:Name="LblDepth" Text="0" HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="Bold"/>
                                </DockPanel>
                                <Slider x:Name="SliderDepth" Minimum="0" Maximum="50" Value="0" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="SliderDepth_ValueChanged" Margin="0,0,0,12"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ============================ TAB 4: ADVANCED ============================ -->
                    <TabItem Header="Advanced">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,14,12,12">

                                <TextBlock Text="PERFORMANCE" FontSize="10" FontWeight="Bold" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.7"/>

                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="CPU Threads" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock x:Name="LblThreads" Text="4" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="Bold"/>
                                        <TextBlock x:Name="LblThreadsMax" Text="" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                                    </StackPanel>
                                </DockPanel>
                                <Slider x:Name="SliderThreads" Minimum="1" Maximum="4" Value="4" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="SliderThreads_ValueChanged" Margin="0,0,0,12"/>

                                <DockPanel Margin="0,0,0,4">
                                    <TextBlock Text="Hash Table (MB)" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock x:Name="LblHash" Text="256" Foreground="{StaticResource AccentBrush}" FontSize="13" FontWeight="Bold"/>
                                        <TextBlock x:Name="LblHashMax" Text="" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                                    </StackPanel>
                                </DockPanel>
                                <Slider x:Name="SliderHash" Minimum="16" Maximum="1024" Value="256" IsSnapToTickEnabled="True" TickFrequency="16" ValueChanged="SliderHash_ValueChanged" Margin="0,0,0,12"/>

                                <TextBlock Text="Move Overhead (ms)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtMoveOverhead" Text="100" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,16"/>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>
                                <TextBlock Text="GAME" FontSize="10" FontWeight="Bold" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.7"/>

                                <TextBlock Text="Variant" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbVariant" SelectedIndex="0" Margin="0,0,0,10">
                                    <ComboBoxItem Content="Standard"/>
                                    <ComboBoxItem Content="Chess960"/>
                                </ComboBox>

                                <TextBlock Text="Preferred Color" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CmbColor" SelectedIndex="0" Margin="0,0,0,10">
                                    <ComboBoxItem Content="Random"/>
                                    <ComboBoxItem Content="White"/>
                                    <ComboBoxItem Content="Black"/>
                                </ComboBox>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>
                                <TextBlock Text="CHAT" FontSize="10" FontWeight="Bold" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.7"/>

                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="Send Chat Messages" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                                    <CheckBox x:Name="ChkChat" IsChecked="True" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitch}"/>
                                </DockPanel>

                                <TextBlock Text="Greeting Message" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtGreeting" Text="glhf!" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,10"/>

                                <TextBlock Text="GG Message" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtGG" Text="gg wp!" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,10"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <Grid Grid.Column="1" Margin="12,10,12,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="TxtConsole" Visibility="Collapsed"/>

                <Border x:Name="ToastBorder" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                        Margin="4,4,4,0" CornerRadius="8" Padding="14,10" Panel.ZIndex="10"
                        Visibility="Collapsed">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FF8a2820" Offset="0"/>
                            <GradientStop Color="#FFb83828" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <DockPanel>
                        <TextBlock Text="!" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White"/>
                        <TextBlock x:Name="TxtToast" Text="" FontSize="12" Foreground="White" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0" Margin="0">
                    <TabItem Header="Dashboard">
                        <Grid Margin="8,12,8,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" CornerRadius="12" Padding="28,22,28,24" Margin="0,0,0,12"
                                    BorderThickness="1" ClipToBounds="True">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#d4985a" Opacity="0.12"/>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF251d16" Offset="0"/>
                                        <GradientStop Color="#FF1b1510" Offset="0.6"/>
                                        <GradientStop Color="#FF16100c" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <!-- Radial glow blob top-right -->
                                    <Ellipse Width="240" Height="240" HorizontalAlignment="Right" VerticalAlignment="Top"
                                             Margin="0,-80,-80,0" IsHitTestVisible="False">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                                <GradientStop Color="#33d4985a" Offset="0"/>
                                                <GradientStop Color="#00d4985a" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="E N G I N E   E V A L U A T I O N" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}" Opacity="0.65" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="LblEval" Text="+0.00" FontSize="56" FontWeight="Bold"
                                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,14"
                                                       LineHeight="56" LineStackingStrategy="BlockLineHeight">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="#d4985a" BlurRadius="24" ShadowDepth="0" Opacity="0.35"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                            <Border CornerRadius="5" Height="10" ClipToBounds="True" Margin="0,0,28,0"
                                                    BorderBrush="#FF2a2018" BorderThickness="1"
                                                    Background="#FF100c08">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition x:Name="EvalWhiteCol" Width="50*"/>
                                                        <ColumnDefinition x:Name="EvalBlackCol" Width="50*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Rectangle Grid.Column="0">
                                                        <Rectangle.Fill>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#FFf2eadd" Offset="0"/>
                                                                <GradientStop Color="#FFd4c8b8" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Rectangle.Fill>
                                                    </Rectangle>
                                                    <Rectangle Grid.Column="1" Fill="#FF0a0805"/>
                                                </Grid>
                                            </Border>
                                            <Grid Margin="0,6,28,0">
                                                <TextBlock x:Name="LblEvalWhite" Text="WHITE · 50%" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.5"
                                                           HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="LblEvalBlack" Text="BLACK · 50%" FontSize="9" FontWeight="Bold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.5"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="28,0,0,0">
                                            <TextBlock Text="G A M E S" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.65"
                                                       HorizontalAlignment="Right" Margin="0,0,0,10"/>
                                            <TextBlock x:Name="LblGamesCount" Text="0" FontSize="56" FontWeight="Bold"
                                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       HorizontalAlignment="Right" LineHeight="56"
                                                       LineStackingStrategy="BlockLineHeight"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>

                            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,12">
                                <Border CornerRadius="10" Padding="14,16,14,14" Margin="0,0,4,0"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Ellipse Width="180" Height="120" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-60,0,0" IsHitTestVisible="False">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#1f6a9b2c" Offset="0"/>
                                                    <GradientStop Color="#006a9b2c" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Border Background="#FF16110d" CornerRadius="10" Opacity="0.5"/>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="W I N S" FontSize="9" FontWeight="Bold"
                                                       Foreground="#FF8ab86a" Opacity="0.85" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="LblWins" Text="0" FontSize="28" FontWeight="Bold"
                                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                                       Foreground="#FF8ab86a" HorizontalAlignment="Center" LineHeight="28"
                                                       LineStackingStrategy="BlockLineHeight"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Border Background="#FF16110d" CornerRadius="10" Padding="14,16,14,14" Margin="4,0,4,0"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="D R A W S" FontSize="9" FontWeight="Bold"
                                                   Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.7" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="LblDraws" Text="0" FontSize="28" FontWeight="Bold"
                                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" LineHeight="28"
                                                   LineStackingStrategy="BlockLineHeight"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="10" Padding="14,16,14,14" Margin="4,0,0,0"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Ellipse Width="180" Height="120" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-60,0,0" IsHitTestVisible="False">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#1fb83828" Offset="0"/>
                                                    <GradientStop Color="#00b83828" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Border Background="#FF16110d" CornerRadius="10" Opacity="0.5"/>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="L O S S E S" FontSize="9" FontWeight="Bold"
                                                       Foreground="#FFe85040" Opacity="0.85" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="LblLosses" Text="0" FontSize="28" FontWeight="Bold"
                                                       FontFamily="Cascadia Mono, Consolas, monospace"
                                                       Foreground="#FFe85040" HorizontalAlignment="Center" LineHeight="28"
                                                       LineStackingStrategy="BlockLineHeight"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </UniformGrid>

                            <Border Grid.Row="2" CornerRadius="12" Padding="18,16,18,12"
                                    Background="#FF16110d" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="R E C E N T   M O V E S" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}" Opacity="0.6" VerticalAlignment="Center"/>
                                        <Rectangle Grid.Column="1" Height="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#33d4985a" Offset="0"/>
                                                    <GradientStop Color="#00d4985a" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                    </Grid>
                                    <ListBox x:Name="RecentMovesList" Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0,0,0,2"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Focusable" Value="False"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <ContentPresenter/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding RowBackground}" CornerRadius="5" Padding="0" Margin="0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="3"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Rectangle Grid.Column="0" Fill="{Binding AccentStrip}" RadiusX="2" RadiusY="2"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="12"
                                                                   VerticalAlignment="Center" Margin="8,4,4,4" Width="16"
                                                                   Foreground="{Binding AccentStrip}" HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Timestamp}" FontSize="10"
                                                                   FontFamily="Cascadia Mono, Consolas" Foreground="#40F0EBE4"
                                                                   VerticalAlignment="Center" Margin="4,4,8,4"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="12"
                                                                   FontFamily="Segoe UI" Foreground="{Binding MessageColor}"
                                                                   TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,4,8,4"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Logs">
                        <DockPanel Margin="8,12,8,0">
                            <ListBox x:Name="ActivityList" Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingPanel.IsVirtualizing="True">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,3"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding RowBackground}" CornerRadius="6" Padding="0" Margin="0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Rectangle Grid.Column="0" Fill="{Binding AccentStrip}" RadiusX="2" RadiusY="2"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Icon}" FontSize="13"
                                                           VerticalAlignment="Center" Margin="10,5,6,5" Width="16"
                                                           Foreground="{Binding AccentStrip}" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Timestamp}" FontSize="10"
                                                           FontFamily="Cascadia Mono, Consolas, monospace"
                                                           Foreground="#40F0EBE4" VerticalAlignment="Center"
                                                           Margin="4,5,10,5"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="12"
                                                           FontFamily="Segoe UI, Cascadia Mono, Consolas"
                                                           Foreground="{Binding MessageColor}" TextWrapping="Wrap"
                                                           VerticalAlignment="Center" Margin="0,5,10,5"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>
                </TabControl>

                <StackPanel Grid.Row="1" Margin="0,6,0,0">
                    <TextBlock x:Name="LblGamesBottom" Text="" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
