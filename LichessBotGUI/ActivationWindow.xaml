<Window x:Class="LichessBotGUI.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lichess Bot — Activation"
        Height="480" Width="520"
        Background="#FF0e0b07"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="app.ico"
        ShowInTaskbar="True">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#FFd4985a"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF0ebe4"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FFA09282"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#FF3a2c20"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="#FF241c15"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFe85040"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#FF6a9b2c"/>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FF241c15"/>
            <Setter Property="Foreground" Value="#FFF0ebe4"/>
            <Setter Property="BorderBrush" Value="#FF3a2c20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#FF241c15"/>
            <Setter Property="Foreground" Value="#FFF0ebe4"/>
            <Setter Property="BorderBrush" Value="#FF3a2c20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF3a5520" Offset="0"/>
                        <GradientStop Color="#FF4e6e2a" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFF0ebe4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="32,24,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Border CornerRadius="8" Width="40" Height="40" Margin="0,0,12,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF3a2a18" Offset="0"/>
                        <GradientStop Color="#FF2a1e12" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="&#x265E;" FontSize="22" Foreground="#FFd4985a"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Lichess Bot" FontSize="18" FontWeight="Bold" Foreground="#FFF0ebe4"/>
                <TextBlock Text="L I C E N S E   A C T I V A T I O N" FontSize="9" FontWeight="Bold" Foreground="#FFd4985a" Opacity="0.8"/>
            </StackPanel>
        </StackPanel>

        <!-- Separator -->
        <Border Grid.Row="2" Height="1" Background="#FF3a2c20"/>

        <!-- Status message -->
        <Border x:Name="StatusBorder" Grid.Row="4" CornerRadius="8" Padding="14,10"
                Background="#FF1a1410" BorderThickness="1" BorderBrush="#FF3a2c20">
            <TextBlock x:Name="TxtStatus"
                       Text="Enter your API token and license key to activate Lichess Bot."
                       Foreground="#FFA09282" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- API Token label -->
        <TextBlock Grid.Row="6" Text="Lichess API Token" FontSize="11"
                   Foreground="#FFA09282"/>

        <!-- API Token input -->
        <PasswordBox x:Name="TxtApiToken" Grid.Row="8"
                 Style="{StaticResource RoundedPasswordBox}"
                 MaxLength="40"
                 ToolTip="Your Lichess API token (lip_...)"/>

        <!-- License Key label -->
        <TextBlock Grid.Row="10" Text="License Key" FontSize="11"
                   Foreground="#FFA09282"/>

        <!-- License Key input -->
        <TextBox x:Name="TxtKey" Grid.Row="12"
                 Style="{StaticResource RoundedTextBox}"
                 CharacterCasing="Upper"
                 MaxLength="47"
                 ToolTip="Format: XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX"/>

        <!-- Buttons row -->
        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnExit" Content="Exit" Width="80"
                    Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"
                    Click="BtnExit_Click">
                <Button.Background>
                    <SolidColorBrush Color="#FF3a2c20"/>
                </Button.Background>
            </Button>
            <Button x:Name="BtnActivate" Content="Activate" Width="120"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnActivate_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
