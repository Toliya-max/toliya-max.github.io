<Window x:Class="LichessBotUninstall.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uninstall Lichess Bot"
        Height="540" Width="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="14" Background="{StaticResource BgDarkBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource BgPanelBrush}" Height="56">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0,0,0">
                    <TextBlock Text="◆" Foreground="{StaticResource RedBrush}" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TitleVersion" Text="Uninstall Lichess Bot"
                               Foreground="{StaticResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="44" Height="44" Margin="0,0,8,0"
                        Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                        BorderThickness="0" Cursor="Hand" FontSize="16"
                        Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3a2018"/>
                                    <Setter Property="Foreground" Value="#e85040"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Pages -->
            <Grid Grid.Row="1">

                <!-- ========= PAGE: CONFIRM ========= -->
                <Grid x:Name="PageConfirm" Visibility="Visible" Margin="36,30,36,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Remove Lichess Bot from this computer?"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22" FontWeight="SemiBold" Margin="0,0,0,18"/>

                    <Border Grid.Row="1" Background="{StaticResource BgPanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="18,14" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="The following will be removed:"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtPathLine" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas" FontSize="13" Margin="0,0,0,4"
                                       TextWrapping="Wrap" Text="• Install folder: …"/>
                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas"
                                       FontSize="13" Margin="0,0,0,4"
                                       Text="• Desktop shortcut (Lichess Bot.lnk)"/>
                            <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas"
                                       FontSize="13"
                                       Text="• Apps &amp; Features registration"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                        <CheckBox x:Name="ChkRemoveCache" Style="{StaticResource ModernCheckBox}"
                                  Content="Also delete cached license, API token and Stockfish engine"
                                  Margin="0,0,0,6"/>
                        <TextBlock Text="If unchecked, your license and API token are kept so a future install restores them automatically."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                                   TextWrapping="Wrap" Margin="24,0,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="3" VerticalAlignment="Bottom" Margin="0,16,0,0"
                            Background="#1f1611" BorderBrush="#3a2418" BorderThickness="1"
                            CornerRadius="6" Padding="14,10">
                        <TextBlock Foreground="#c9a070" FontSize="12" TextWrapping="Wrap"
                                   Text="This action cannot be undone. Make sure no game is in progress before continuing."/>
                    </Border>
                </Grid>

                <!-- ========= PAGE: PROGRESS ========= -->
                <Grid x:Name="PageProgress" Visibility="Collapsed" Margin="36,30,36,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Removing Lichess Bot…"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                    <Border Grid.Row="1" Height="6" Background="#1f1611"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="3" Margin="0,0,0,14" HorizontalAlignment="Stretch">
                        <Border x:Name="ProgressFill" Width="0" Height="4" HorizontalAlignment="Left"
                                CornerRadius="2">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#c94335" Offset="0"/>
                                    <GradientStop Color="#e8584a" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Border>

                    <Border Grid.Row="2" Background="{StaticResource BgPanelBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="14,10">
                        <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="TxtLog" Foreground="{StaticResource TextPrimaryBrush}"
                                       FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- ========= PAGE: COMPLETE ========= -->
                <Grid x:Name="PageComplete" Visibility="Collapsed" Margin="36,30,36,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="84" Height="84" CornerRadius="42"
                                Background="#1d2e14" BorderBrush="{StaticResource GreenBrush}" BorderThickness="2"
                                Margin="0,0,0,20">
                            <TextBlock Text="✓" FontSize="48" FontWeight="Bold"
                                       Foreground="{StaticResource GreenBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Lichess Bot has been uninstalled"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TxtCompleteSub"
                                   Text="All program files and registry entries were removed."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13" HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" MaxWidth="480"/>
                    </StackPanel>
                </Grid>

                <!-- ========= PAGE: ERROR ========= -->
                <Grid x:Name="PageError" Visibility="Collapsed" Margin="36,30,36,0">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="84" Height="84" CornerRadius="42"
                                Background="#3a1815" BorderBrush="{StaticResource RedBrush}" BorderThickness="2"
                                Margin="0,0,0,20" HorizontalAlignment="Center">
                            <TextBlock Text="!" FontSize="48" FontWeight="Bold"
                                       Foreground="{StaticResource RedBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Uninstall did not complete"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <Border Background="{StaticResource BgPanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,8,0,0">
                            <TextBlock x:Name="TxtErrorDetail" Foreground="#e8584a"
                                       FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                        </Border>
                        <TextBlock Text="Close any open Lichess Bot windows in Task Manager and try again, or delete the install folder manually."
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>

            </Grid>

            <!-- Bottom buttons -->
            <Grid Grid.Row="2" Background="{StaticResource BgPanelBrush}" Height="78">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,22,0">
                    <Button x:Name="BtnCancel" Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Width="120" Margin="0,0,12,0" Click="BtnCancel_Click"/>
                    <Button x:Name="BtnUninstall" Content="Uninstall" Style="{StaticResource DangerButton}"
                            Width="160" Click="BtnUninstall_Click"/>
                    <Button x:Name="BtnFinish" Content="Close" Style="{StaticResource GreenButton}"
                            Width="160" Click="BtnFinish_Click" Visibility="Collapsed"/>
                    <Button x:Name="BtnRetry" Content="Retry" Style="{StaticResource DangerButton}"
                            Width="160" Click="BtnRetry_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
